{
	"productName": "Dashshund",
	"identifier": "com.team581.dashshund",
	"build": {
		"frontendDist": "../dist-renderer",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun vite dev",
		"beforeBuildCommand": "bun vite build"
	},
	"app": {
		"windows": [
			{
				"title": "Dashshund",
				"width": 1280,
				"height": 720,
				"maximized": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "nsis"],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"macOS": {
			"files": {
				"Resources/AppIcon.icon": "../assets/mac.icon"
			}
		}
	},
	"plugins": {
		"opener": {}
	}
}
