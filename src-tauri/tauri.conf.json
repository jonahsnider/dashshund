		"windows": [
			{
				"height": 720,
				"maximized": true,
				"title": "Dashshund",
				"visible": false,
				"width": 1280
			}
		]
	},
	"build": {
		"beforeBuildCommand": "bun vite build",
		"beforeDevCommand": "bun vite dev",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../dist-renderer"
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"macOS": {
			"files": {
				"Resources/AppIcon.icon": "../assets/mac.icon"
			},
			"signingIdentity": "-"
		},
		"targets": ["dmg", "nsis"],
		"windows": {
			"nsis": {
				"installMode": "currentUser"
			}
		}
	},
	"identifier": "com.team581.dashshund",
	"plugins": {
		"opener": {},
