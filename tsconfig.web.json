{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"composite": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"include": ["src/renderer/**/*", "vite.config.ts"]
}
