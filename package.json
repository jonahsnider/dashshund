{
	"name": "dashshund",
	"version": "2026.0.3",
	"description": "FRC dashboard for viewing camera streams",
	"author": "Team 581",
	"private": true,
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"package": "electron-vite build && electron-builder",
		"lint": "biome check",
		"lint:fix": "biome check --write --unsafe",
		"generate-icons": "pwa-assets-generator"
	},
	"dependencies": {
		"@solid-primitives/storage": "^4.3.4",
		"@tailwindcss/vite": "^4.2.1",
		"ntcore-ts-client": "^3.1.3",
		"solid-js": "^1.9.5",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@electron-toolkit/utils": "^4.0.0",
		"@vite-pwa/assets-generator": "^1.0.2",
		"electron": "^40.0.0",
		"electron-builder": "^25.1.8",
		"electron-vite": "^5.0.0",
		"typescript": "^5.7.3",
		"vite": "^6",
		"vite-plugin-solid": "^2.11.6"
	},
	"build": {
		"appId": "com.team581.dashshund",
		"productName": "Dashshund",
		"directories": {
			"output": "dist"
		},
		"mac": {
			"icon": "build/icon-1024x1024.png",
			"target": [
				"dmg"
			]
		},
		"win": {
			"icon": "build/icon-1024x1024.png",
			"target": [
				"nsis"
			]
		}
	},
	"patchedDependencies": {
		"ntcore-ts-client@3.1.3": "patches/ntcore-ts-client@3.1.3.patch"
	}
}
