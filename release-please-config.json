{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"packages": {
		".": {
			"release-type": "node",
			"component": "dashshund",
			"extra-files": [
				{
					"type": "json",
					"path": "src-tauri/tauri.conf.json",
					"jsonpath": "$.version"
				}
			]
		},
		"src-tauri": {
			"release-type": "rust",
			"component": "dashshund-tauri"
		}
	},
	"plugins": [
		{
			"type": "linked-versions",
			"groupName": "dashshund",
			"components": ["dashshund", "dashshund-tauri"]
		}
	]
}
